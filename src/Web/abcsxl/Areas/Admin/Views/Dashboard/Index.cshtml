@model abcsxl.Areas.Admin.Models.ViewModels.Dashboard.IndexPageViewModel

@{
    ViewData["Title"] = "仪表盘";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">📊 仪表盘</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">欢迎回来，这里是你的博客管理概览。</p>

        <div class="row mb-4">
            <div class="col-md-2">
                <div class="card text-center bg-primary text-white">
                    <div class="card-body">
                        <h4>@Model.TotalPosts</h4>
                        <small class="text-white">总文章</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card text-center bg-success text-white">
                    <div class="card-body">
                        <h4>@Model.PublishedPosts</h4>
                        <small class="text-white">已发布</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card text-center bg-info text-white">
                    <div class="card-body">
                        <h4>@Model.TotalCategories</h4>
                        <small class="text-white">分类</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card text-center bg-warning text-white">
                    <div class="card-body">
                        <h4>@Model.TotalTags</h4>
                        <small class="text-white">标签</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card text-center bg-secondary text-white">
                    <div class="card-body">
                        <h4>@Model.TotalUsers</h4>
                        <small class="text-white">用户</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card text-center bg-danger text-white">
                    <div class="card-body">
                        <h4>@Model.TotalComments</h4>
                        <small class="text-white">评论</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">📝 最新文章</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentPosts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>标题</th>
                                    <th>作者</th>
                                    <th>发布时间</th>
                                    <th>状态</th>
                                    <th style="width: 100px;">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var post in Model.RecentPosts)
                                {
                                    <tr>
                                        <td>@post.Title</td>
                                        <td>@post.AuthorName</td>
                                        <td>
                                            @(post.PublishedAt?.ToString("yyyy-MM-dd") ?? "—")
                                        </td>
                                        <td>
                                            @if (post.IsPublished)
                                            {
                                                <span class="badge bg-success">已发布</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">草稿</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-area="Admin" asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted">暂无文章</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>