@model IEnumerable<abcsxl.Models.Entities.Post>
@using abcsxl.Models.Enums

@{
    ViewData["Title"] = T["PageTitle"].Value;
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var search = ViewBag.Search as string;
    var status = ViewBag.Status as string;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@T["HeaderTitle"]</h5>
        <a asp-area="Admin" asp-controller="Post" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> @T["CreateButton"]
        </a>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="@T["SearchPlaceholder"]" value="@search">
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">@T["StatusAll"]</option>
                        <option value="Draft" selected="@(status == "Draft")">@T["StatusDraft"]</option>
                        <option value="Published" selected="@(status == "Published")">@T["StatusPublished"]</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search"></i> @T["SearchButton"]
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(status))
                {
                    <div class="col-md-2">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-x-circle"></i> @T["ResetButton"]
                        </a>
                    </div>
                }
            </div>
        </form>

        @if (Model.Any())
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>@T["TableHeaderTitle"]</th>
                        <th>@T["TableHeaderAuthor"]</th>
                        <th>@T["TableHeaderViews"]</th>
                        <th>@T["TableHeaderPublishDate"]</th>
                        <th>@T["TableHeaderStatus"]</th>
                        <th style="width: 120px;">@T["TableHeaderActions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td>
                                <a asp-area="" asp-controller="Post" asp-action="Detail" asp-route-id="@post.Slug" target="_blank">
                                    @post.Title
                                </a>
                            </td>
                            <td>@post.Author.Username</td>
                            <td><span class="text-muted">@post.ViewCount</span></td>
                            <td>
                                @(post.PublishedAt?.ToString("yyyy-MM-dd") ?? "—")
                            </td>
                            <td>
                                @if (post.Status == PostStatus.Published)
                                {
                                    <span class="badge bg-success">@T["StatusPublished"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@T["StatusDraft"]</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-area="Admin" asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-primary" title="@T["ActionEdit"]">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-area="" asp-controller="Post" asp-action="Detail" asp-route-id="@post.Slug" class="btn btn-outline-secondary" target="_blank" title="@T["ActionView"]">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Post" asp-action="Delete" asp-route-id="@post.Id" class="btn btn-outline-danger" title="@T["ActionDelete"]">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <nav aria-label="@T["PaginationAriaLabel"]">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@search" asp-route-status="@status">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (var i = 1; i <= totalPages; i++)
                        {
                            @if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search" asp-route-status="@status">@i</a>
                                </li>
                            }
                            else if (i == currentPage - 3 || i == currentPage + 3)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@search" asp-route-status="@status">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-5">
                <p class="text-muted">@T["NoPosts"]</p>
            </div>
        }
    </div>
</div>
