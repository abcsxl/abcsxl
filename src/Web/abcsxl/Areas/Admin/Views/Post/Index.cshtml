@* <link href="DataTables/datatables.min.css" rel="stylesheet">
<script src="DataTables/datatables.min.js"></script> *@

<div class="card">
    <div class="card-header">
        <h5>📝 所有文章</h5>
    </div>
    <div class="card-body">
        <a asp-area="Admin" asp-controller="Post" asp-action="Create" class="btn btn-primary">+ 新建文章</a>
        @if (Model.Any())
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>标题</th>
                        <th>作者</th>
                        <th>发布时间</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td>@post.Title</td>
                            <td>@post.Author.Username</td>
                            <td>
                                @(post.PublishedAt?.ToString("yyyy-MM-dd") ?? "未发布")
                            </td>
                            <td>
                                @post.Status
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id" class="btn btn-sm btn-outline-primary">编辑</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">暂无文章。</p>
        }
    </div>
</div>

