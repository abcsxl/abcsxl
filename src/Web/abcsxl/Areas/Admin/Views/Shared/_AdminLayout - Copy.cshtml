<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes, viewport-fit=cover">
    <title>@ViewData["Title"] - 管理后台</title>

    <!-- Bootstrap 5.3.3 + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- 手机遮罩层 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <!-- 侧边栏 -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-inner">
            <!-- 用户信息卡片（手机端） -->
            <div class="user-card d-lg-none">
                <div class="d-flex align-items-center">
                    <div class="user-avatar me-3">
                        @(User.Identity?.Name?.TrimStart().Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "A")
                    </div>
                    <div>
                        <div class="fw-bold" style="color: #1e293b;">@(User.Identity?.Name ?? "管理员")</div>
                        <small class="text-muted">系统管理员</small>
                    </div>
                </div>
            </div>

            <!-- 用户信息卡片（PC端） -->
            <div class="user-card d-none d-lg-block">
                <div class="d-flex align-items-center">
                    <div class="user-avatar me-3">
                        @(User.Identity?.Name?.TrimStart().Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "A")
                    </div>
                    <div>
                        <div class="fw-bold" style="color: #1e293b;">@(User.Identity?.Name ?? "管理员")</div>
                        <small class="text-muted">系统管理员</small>
                    </div>
                </div>
            </div>

            <!-- 导航菜单 -->
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>仪表盘</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Posts" ? "active" : "")"
                       asp-area="Admin" asp-controller="Posts" asp-action="Index">
                        <i class="bi bi-file-text"></i>
                        <span>文章管理</span>
                        <span class="badge bg-primary rounded-pill">12</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")"
                       asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="bi bi-folder"></i>
                        <span>分类管理</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#userMenu" role="button" aria-expanded="false">
                        <i class="bi bi-people"></i>
                        <span>用户管理</span>
                        <i class="bi bi-chevron-down float-end"></i>
                    </a>
                    <div class="collapse" id="userMenu">
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-person"></i>
                                    <span>用户列表</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Roles" ? "active" : "")"
                                   asp-area="Admin" asp-controller="Roles" asp-action="Index">
                                    <i class="bi bi-shield"></i>
                                    <span>角色管理</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")"
                       asp-area="Admin" asp-controller="Settings" asp-action="Index">
                        <i class="bi bi-gear"></i>
                        <span>系统设置</span>
                    </a>
                </li>
            </ul>

            <hr class="sidebar-divider">

            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door"></i>
                        <span>返回前台</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-danger" asp-area="Admin" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>退出登录</span>
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- 顶部导航栏 -->
    <nav class="navbar-top">
        <div class="d-flex align-items-center">
            <!-- 菜单按钮（手机端） -->
            <button class="btn btn-link text-white sidebar-toggle me-3 p-1" type="button" id="sidebarToggle">
                <i class="bi bi-list fs-3"></i>
            </button>

            <a class="navbar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-grid"></i>
                <span>Admin Panel</span>
            </a>
        </div>

        <div class="d-flex align-items-center gap-3">
            <!-- 暗黑模式 -->
            <button class="btn btn-link text-white p-1" id="darkModeToggle" title="切换主题">
                <i class="bi bi-moon-fill fs-5"></i>
            </button>

            <!-- 通知 -->
            <div class="dropdown">
                <button class="btn btn-link text-white p-1 position-relative" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-bell fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; padding: 0.25rem 0.4rem;">
                        3
                    </span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">通知</h6></li>
                    <li>
                        <a class="dropdown-item" href="#">
                            <small class="text-muted d-block">5分钟前</small>
                            <span>有3条评论待审核</span>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="#">
                            <small class="text-muted d-block">1小时前</small>
                            <span>系统更新完成</span>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-center" href="#">查看全部</a></li>
                </ul>
            </div>

            <!-- 用户菜单 -->
            <div class="dropdown">
                <button class="btn btn-link text-white p-0" type="button" data-bs-toggle="dropdown">
                    <div class="user-avatar" style="width: 38px; height: 38px; font-size: 1rem;">
                        @(User.Identity?.Name?.TrimStart().Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "A")
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li class="dropdown-header d-flex align-items-center py-3 px-3">
                        <div class="user-avatar me-3" style="width: 45px; height: 45px;">
                            @(User.Identity?.Name?.TrimStart().Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "A")
                        </div>
                        <div>
                            <div class="fw-bold fs-6">@(User.Identity?.Name ?? "管理员")</div>
                            <small class="text-muted">admin@example.com</small>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" asp-area="Admin" asp-controller="Account" asp-action="Profile">
                            <i class="bi bi-person"></i> 个人资料
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-area="Admin" asp-controller="Account" asp-action="ChangePassword">
                            <i class="bi bi-lock"></i> 修改密码
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear"></i> 系统设置
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" asp-area="Admin" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right"></i> 退出登录
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- 主内容区 -->
    <main class="main-content page-transition" id="mainContent">
        <!-- 面包屑 -->
        <div class="breadcrumb-wrapper">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>
                            <span>首页</span>
                        </a>
                    </li>
                    @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()))
                    {
                        <li class="breadcrumb-item active">@ViewData["Title"]</li>
                    }
                </ol>
            </nav>
        </div>

        <!-- 页面标题 -->
        @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()))
        {
            <h1 class="page-title">@ViewData["Title"]</h1>
        }

        <!-- 页面内容 -->
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>