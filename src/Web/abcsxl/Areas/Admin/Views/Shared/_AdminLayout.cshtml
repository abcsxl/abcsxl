<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name" data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes">
    <title>@ViewData["Title"] - @T["PageTitleSuffix"]</title>

    <!-- Bootstrap 5.3.3 + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- 手机遮罩层 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <!-- 侧边栏 - 真正可折叠 -->
    <div class="sidebar" id="sidebar">
        <!-- 侧边栏头部 -->
        <div class="sidebar-header">
            <a class="sidebar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-grid"></i>
                <span>@T["BrandTitle"]</span>
            </a>
            <button class="sidebar-toggle-pc" id="sidebarTogglePC" title="@T["SidebarCollapseTitle"]">
                <i class="bi bi-chevron-left"></i>
            </button>
        </div>

        <!-- 用户信息 -->
        <div class="user-info">
            <div class="user-avatar">
                @{
                    var userName = User.Identity?.Name ?? T["UserDefaultName"].Value;
                    var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "A";
                }
                @initial
            </div>
            <div class="user-details">
                <div class="user-name">@userName</div>
                <div class="user-role">
                    @{
                        var role = ViewBag.UserRole ?? T["UserDefaultRole"].Value;
                    }
                    <span class="badge bg-primary">@role</span>
                </div>
            </div>
        </div>

        <!-- 导航菜单 -->
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>@T["NavDashboard"]</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Post" ? "active" : "")"
                   asp-area="Admin" asp-controller="Post" asp-action="Index">
                    <i class="bi bi-file-text"></i>
                    <span>@T["NavPostManagement"]</span>
                    <span class="badge">12</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                   asp-area="Admin" asp-controller="Category" asp-action="Index">
                    <i class="bi bi-folder"></i>
                    <span>@T["NavCategoryManagement"]</span>
                </a>
            </li>

            @if (role == "Admin")
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
                       asp-area="Admin" asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span>@T["NavUserManagement"]</span>
                    </a>
                </li>
            }

            @* 系统设置 - 所有人可见 *@
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Setting" ? "active" : "")"
                   asp-area="Admin" asp-controller="Setting" asp-action="Index">
                    <i class="bi bi-gear"></i>
                    <span>@T["NavSetting"]</span>
                </a>
            </li>

            @if (role == "Admin" || role == "Editor")
            {
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Comment" ? "active" : "")"
                       asp-area="Admin" asp-controller="Comment" asp-action="Index">
                        <i class="bi bi-chat"></i>
                        <span>@T["NavCommentManagement"]</span>
                    </a>
                </li>
            }

            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i>
                    <span>@T["NavBackToSite"]</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-danger" asp-area="" asp-controller="Account" asp-action="Logout">
<i class="bi bi-box-arrow-right"></i>
                    <span>@T["NavLogout"]</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- 顶部导航栏 -->
    <nav class="navbar-top" id="navbarTop">
        <div class="d-flex align-items-center">
            <!-- PC端折叠按钮 -->
            <button class="sidebar-toggle-pc-nav" id="sidebarTogglePCNav" title="@T["SidebarCollapseTitle"]">
                <i class="bi bi-list"></i>
            </button>

            <!-- 手机端菜单按钮 -->
            <button class="sidebar-toggle-mobile" id="sidebarToggleMobile" title="@T["SidebarExpandTitle"]">
                <i class="bi bi-list"></i>
            </button>

            <!-- 面包屑（PC端显示在导航栏） -->
            <div class="d-none d-md-block">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 bg-transparent p-0">
                        <li class="breadcrumb-item">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" style="color: #6c757d; text-decoration: none;">
                                @T["BreadcrumbHome"]
                            </a>
                        </li>
                        @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()))
                        {
                            <li class="breadcrumb-item active">@ViewData["Title"]</li>
                        }
                    </ol>
                </nav>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3">
            <!-- 暗黑模式切换 -->
            <button class="btn btn-link p-1" id="darkModeToggle" title="@T["ToggleThemeTitle"]" style="color: #4a5568;">
                <i class="bi bi-moon-fill fs-5"></i>
            </button>

            <!-- 通知 -->
            <div class="dropdown">
                <button class="btn btn-link p-1 position-relative" type="button" data-bs-toggle="dropdown" style="color: #4a5568;">
                    <i class="bi bi-bell fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        3
                    </span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">@T["NotificationTitle"]</h6></li>
                    <li>
                        <a class="dropdown-item" href="#">
                            <small class="text-muted d-block">@T["NotificationTime5Min"]</small>
                            <span>@T["NotificationContent1"]</span>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="#">
                            <small class="text-muted d-block">@T["NotificationTime1Hour"]</small>
                            <span>@T["NotificationContent2"]</span>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-center" href="#">@T["NotificationViewAll"]</a></li>
                </ul>
            </div>

            <div class="ms-2">
                @await Html.PartialAsync("_LanguageSwitcher")
            </div>

            <!-- 用户下拉菜单 -->
            <div class="dropdown">
                <button class="btn btn-link p-0" type="button" data-bs-toggle="dropdown" style="color: #4a5568;">
                    <div class="user-avatar" style="width: 38px; height: 38px; background: var(--sidebar-active);">
                        @initial
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li class="dropdown-header d-flex align-items-center py-3 px-3">
                        <div class="user-avatar me-3" style="width: 45px; height: 45px;">
                            @initial
                        </div>
                        <div>
                            <div class="fw-bold fs-6">@userName</div>
                            <small class="text-muted">@(ViewBag.UserEmail ?? "admin@example.com")</small>
                        </div>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                            <i class="bi bi-person"></i> @T["UserMenuProfile"]
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="ChangePassword">
                            <i class="bi bi-lock"></i> @T["UserMenuChangePassword"]
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" asp-area="" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right"></i> @T["NavLogout"]
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- 主内容区 -->
    <main class="main-content" id="mainContent">
        <!-- 手机端显示面包屑 -->
        <div class="d-md-none breadcrumb-wrapper">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>
                            <span>@T["BreadcrumbHome"]</span>
                        </a>
                    </li>
                    @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()))
                    {
                        <li class="breadcrumb-item active">@ViewData["Title"]</li>
                    }
                </ol>
            </nav>
        </div>

        <!-- 页面标题 -->
        @if (!string.IsNullOrEmpty(ViewData["Title"]?.ToString()))
        {
            <h1 class="page-title">@ViewData["Title"]</h1>
        }

        <!-- 页面内容 -->
        @RenderBody()
    </main>

    <!-- jQuery + Validation Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
