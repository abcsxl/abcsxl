@using abcsxl.Models.ViewModels.Account
@*
    ============================================
    修改密码页面 - ChangePassword.cshtml
    ============================================
*@

@model ChangePasswordViewModel
@{
    ViewData["Title"] = "修改密码";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card">
            <div class="d-flex align-items-center mb-4">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                    <i class="bi bi-shield-lock fs-4" style="color: var(--sidebar-active);"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-1">修改密码</h4>
                    <p class="text-muted mb-0">为了账户安全，请定期更换密码</p>
                </div>
            </div>

            <hr class="mb-4">

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success d-flex align-items-center mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <span>密码修改成功！下次登录请使用新密码。</span>
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="form-label fw-medium">
                        <i class="bi bi-lock me-2"></i>当前密码
                    </label>
                    <input type="password" class="form-control" name="CurrentPassword" placeholder="请输入当前密码" required>
                    <div class="form-text">为验证身份，请输入当前使用的密码</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">
                        <i class="bi bi-key me-2"></i>新密码
                    </label>
                    <input type="password" class="form-control" name="NewPassword" placeholder="请输入新密码" required>
                    <div class="form-text">密码长度至少8位，包含字母和数字</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">
                        <i class="bi bi-check-circle me-2"></i>确认新密码
                    </label>
                    <input type="password" class="form-control" name="ConfirmPassword" placeholder="请再次输入新密码" required>
                </div>

                <!-- 密码强度提示 -->
                <div class="password-strength mb-4 p-3 bg-light rounded-3">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-shield me-2"></i>
                        <span class="fw-medium">密码强度</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: 33%;"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2 small">
                        <span class="text-danger">弱</span>
                        <span class="text-muted">中</span>
                        <span class="text-muted">强</span>
                    </div>
                    <ul class="mt-3 small text-muted mb-0">
                        <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i> 长度至少8位</li>
                        <li class="mb-1"><i class="bi bi-x-circle-fill text-danger me-1"></i> 包含大写字母</li>
                        <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i> 包含小写字母</li>
                        <li class="mb-1"><i class="bi bi-x-circle-fill text-danger me-1"></i> 包含数字</li>
                        <li class="mb-1"><i class="bi bi-x-circle-fill text-danger me-1"></i> 包含特殊字符</li>
                    </ul>
                </div>

                <!-- 安全提示 -->
                <div class="alert alert-warning d-flex align-items-start mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
                    <div>
                        <strong>密码安全建议：</strong>
                        <ul class="mb-0 mt-1 ps-3">
                            <li>不要与其他网站使用相同密码</li>
                            <li>不要使用个人信息作为密码</li>
                            <li>建议每3个月更换一次密码</li>
                        </ul>
                    </div>
                </div>

                <hr class="my-4">

                <div class="d-flex gap-3 justify-content-end">
                    <button type="button" class="btn btn-light px-4" onclick="location.href='@Url.Action("Profile")'">
                        <i class="bi bi-arrow-left me-2"></i>返回
                    </button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>确认修改
                    </button>
                </div>
            </form>
        </div>

        <!-- 最近登录设备 -->
        <div class="content-card mt-4">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-device fs-5 me-2" style="color: var(--sidebar-active);"></i>
                <h5 class="fw-bold mb-0">最近登录设备</h5>
            </div>

            <div class="list-group list-group-flush">
                <div class="list-group-item d-flex align-items-center px-0">
                    <div class="me-3">
                        <i class="bi bi-laptop fs-4 text-primary"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <span class="fw-medium">Windows PC - Chrome</span>
                            <span class="badge bg-success">当前设备</span>
                        </div>
                        <small class="text-muted">IP: 192.168.1.100 · 5分钟前</small>
                    </div>
                </div>
                <div class="list-group-item d-flex align-items-center px-0">
                    <div class="me-3">
                        <i class="bi bi-phone fs-4 text-secondary"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <span class="fw-medium">iPhone 15 - Safari</span>
                            <button class="btn btn-link btn-sm text-danger p-0">下线</button>
                        </div>
                        <small class="text-muted">IP: 192.168.1.101 · 2天前</small>
                    </div>
                </div>
            </div>

            <div class="mt-3 text-end">
                <button class="btn btn-link text-danger p-0">
                    <i class="bi bi-x-circle me-1"></i>全部设备下线
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .password-strength {
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,0.05);
    }

    [data-bs-theme="dark"] .password-strength {
        background: #2c3034 !important;
        border-color: rgba(255,255,255,0.1);
    }

    [data-bs-theme="dark"] .list-group-item {
        background: transparent;
        border-color: rgba(255,255,255,0.1);
    }

    .alert {
        border-radius: 12px;
        border: none;
    }

    .btn-link {
        text-decoration: none;
    }

        .btn-link:hover {
            text-decoration: underline;
        }
</style>