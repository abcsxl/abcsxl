@model abcsxl.Models.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "修改密码";
}

<header class="masthead" style="background-image: url('../images/home-bg.webp')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-9 col-xl-8">
                <div class="site-heading">
                    <h1>@ViewData["Title"]</h1>
                    <span class="subheading">
                        为了账户安全，请定期更换密码
                    </span>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="container px-4 px-lg-5">
    <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-md-10 col-lg-9 col-xl-8">
            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    密码修改成功！下次登录请使用新密码。
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">当前密码</label>
                            <input type="password" class="form-control" name="CurrentPassword" placeholder="请输入当前密码" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">新密码</label>
                            <input type="password" class="form-control" name="NewPassword" placeholder="请输入新密码" required>
                            <div class="form-text">密码长度至少8位</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">确认新密码</label>
                            <input type="password" class="form-control" name="ConfirmPassword" placeholder="请再次输入新密码" required>
                        </div>

                        <hr>

                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" onclick="location.href='@Url.Action("Profile")'">
                                <i class="bi bi-arrow-left me-2"></i>返回
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>确认修改
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>