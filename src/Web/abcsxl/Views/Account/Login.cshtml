@using abcsxl.Models.ViewModels.Account
@model LoginViewModel
@{
    ViewData["Title"] = T["PageTitle"].Value;
    Layout = null;
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "/" : Context.Request.Path + Context.Request.QueryString;
    var darkModeText = T["DarkModeText"].Value;
    var lightModeText = T["LightModeText"].Value;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name" data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes">
    <title>@ViewData["Title"] - @T["PanelTitle"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --primary-color: #0d6efd;
            --sidebar-bg: #1e2a3a;
            --content-bg: #f4f6f9;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(145deg, var(--content-bg) 0%, #e9ecef 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            margin: 0 auto;
        }

        .login-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            padding: 2.5rem 2rem;
            border: 1px solid rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-logo {
            width: 72px;
            height: 72px;
            background: linear-gradient(145deg, var(--primary-color), #0b5ed7);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            box-shadow: 0 10px 20px rgba(13,110,253,0.2);
        }

            .login-logo i {
                font-size: 2.5rem;
                color: white;
            }

        .login-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.5rem;
        }

        .login-subtitle {
            color: #64748b;
            font-size: 0.95rem;
        }

        .form-floating {
            margin-bottom: 1rem;
        }

            .form-floating > .form-control {
                border-radius: 12px;
                border: 2px solid #e2e8f0;
                padding: 1rem 0.75rem;
                height: auto;
                transition: all 0.2s;
            }

                .form-floating > .form-control:focus {
                    border-color: var(--primary-color);
                    box-shadow: 0 0 0 4px rgba(13,110,253,0.1);
                }

            .form-floating > label {
                padding: 1rem 0.75rem;
                color: #64748b;
            }

        .form-check {
            margin-top: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .form-check-input {
            width: 1.2rem;
            height: 1.2rem;
            margin-top: 0.1rem;
            border: 2px solid #cbd5e1;
            border-radius: 6px;
        }

            .form-check-input:checked {
                background-color: var(--primary-color);
                border-color: var(--primary-color);
            }

        .btn-login {
            background: linear-gradient(145deg, var(--primary-color), #0b5ed7);
            border: none;
            border-radius: 12px;
            padding: 0.875rem;
            font-weight: 600;
            font-size: 1rem;
            color: white;
            width: 100%;
            transition: all 0.2s;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 12px rgba(13,110,253,0.2);
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(13,110,253,0.3);
            }

            .btn-login i {
                margin-right: 0.5rem;
            }

        .login-footer {
            text-align: center;
            color: #64748b;
            font-size: 0.9rem;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #e2e8f0;
        }

        .alert {
            border-radius: 12px;
            border: none;
            padding: 1rem;
            margin-bottom: 1.5rem;
            background-color: #fee2e2;
            color: #991b1b;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .alert i {
                font-size: 1.1rem;
            }

        [data-bs-theme="dark"] body {
            background: linear-gradient(145deg, #0f172a 0%, #1e293b 100%);
        }

        [data-bs-theme="dark"] .login-card {
            background: #1e293b;
            border-color: rgba(255,255,255,0.05);
        }

        [data-bs-theme="dark"] .login-title {
            color: #f1f5f9;
        }

        [data-bs-theme="dark"] .login-subtitle {
            color: #94a3b8;
        }

        [data-bs-theme="dark"] .form-floating > .form-control {
            background-color: #2c3034;
            border-color: #475569;
            color: #e2e8f0;
        }

        [data-bs-theme="dark"] .form-floating > label {
            color: #94a3b8;
        }

        [data-bs-theme="dark"] .login-footer {
            border-top-color: #475569;
            color: #94a3b8;
        }

        .theme-toggle {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 30px;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        [data-bs-theme="dark"] .theme-toggle {
            background: #1e293b;
            border-color: #475569;
            color: #e2e8f0;
        }

        .lang-toggle {
            position: absolute;
            top: 1.5rem;
            left: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="lang-toggle">
        <form asp-controller="Language" asp-action="Set" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            @if (currentCulture == "zh")
            {
                <button type="submit" name="culture" value="en-US" class="btn btn-sm btn-outline-secondary">English</button>
            }
            else
            {
                <button type="submit" name="culture" value="zh-CN" class="btn btn-sm btn-outline-secondary">中文</button>
            }
        </form>
    </div>

    <div class="theme-toggle" id="darkModeToggle">
        <i class="bi bi-moon-fill"></i>
        <span>@darkModeText</span>
    </div>

    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <i class="bi bi-grid"></i>
                </div>
                <h1 class="login-title">@T["WelcomeBack"]</h1>
                <p class="login-subtitle">@T["LoginSubtitle"]</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@T["LoginError"]</span>
                </div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="form-floating">
                    <input type="email" class="form-control" id="email" name="Email" placeholder="name@example.com" value="@Model?.Email" required>
                    <label for="email"><i class="bi bi-envelope me-2"></i>@T["EmailLabel"]</label>
                </div>

                <div class="form-floating">
                    <input type="password" class="form-control" id="password" name="Password" placeholder="@T["PasswordLabel"]" required>
                    <label for="password"><i class="bi bi-lock me-2"></i>@T["PasswordLabel"]</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe" name="RememberMe">
                    <label class="form-check-label" for="rememberMe">@T["RememberMe"]</label>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i>@T["LoginButton"]
                </button>

                <div class="text-center">
                    <a href="#" class="text-decoration-none" style="color: var(--primary-color);">
                        @T["ForgotPassword"]
                    </a>
                </div>
            </form>

            <div class="login-footer">
                <p class="mb-0">© @DateTime.Now.Year @T["FooterCMS"]</p>
            </div>
        </div>
    </div>

    <script>
        const darkModeText = @Html.Raw(Json.Serialize(darkModeText));
        const lightModeText = @Html.Raw(Json.Serialize(lightModeText));

        const darkModeToggle = document.getElementById('darkModeToggle');
        const html = document.documentElement;

        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-bs-theme', savedTheme);
        updateThemeButton(savedTheme);

        darkModeToggle.addEventListener('click', function() {
            const currentTheme = html.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

            html.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeButton(newTheme);
        });

        function updateThemeButton(theme) {
            const icon = darkModeToggle.querySelector('i');
            const text = darkModeToggle.querySelector('span');

            if (theme === 'dark') {
                icon.className = 'bi bi-sun-fill';
                text.textContent = lightModeText;
            } else {
                icon.className = 'bi bi-moon-fill';
                text.textContent = darkModeText;
            }
        }
    </script>
</body>
</html>
