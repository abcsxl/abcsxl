@{
    Layout = null;
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "/" : Context.Request.Path + Context.Request.QueryString;
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="refresh" content="3;url=@Url.Action("Login", "Account", new { area = "Admin" })">
    <title>@T["PageTitle"] - @T["PanelTitle"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(145deg, #f4f6f9 0%, #e9ecef 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
        }

        .logout-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            padding: 3rem 2.5rem;
            max-width: 500px;
            width: 90%;
            text-align: center;
        }

        .logout-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(145deg, #10b981, #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }

            .logout-icon i {
                font-size: 2.5rem;
                color: white;
            }

        .logout-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.75rem;
        }

        .logout-message {
            color: #64748b;
            margin-bottom: 2rem;
        }

        .spinner {
            width: 40px;
            height: 40px;
            margin: 0 auto 1.5rem;
            border: 4px solid rgba(13,110,253,0.1);
            border-top-color: var(--sidebar-active);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .btn-login {
            background: linear-gradient(145deg, #0d6efd, #0b5ed7);
            border: none;
            border-radius: 12px;
            padding: 0.75rem 2rem;
            font-weight: 600;
            color: white;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(13,110,253,0.2);
                color: white;
            }

        [data-bs-theme="dark"] body {
            background: linear-gradient(145deg, #0f172a 0%, #1e293b 100%);
        }

        [data-bs-theme="dark"] .logout-card {
            background: #1e293b;
        }

        [data-bs-theme="dark"] .logout-title {
            color: #f1f5f9;
        }

        [data-bs-theme="dark"] .logout-message {
            color: #94a3b8;
        }

        .lang-toggle {
            position: absolute;
            top: 1.5rem;
            left: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="lang-toggle">
        <form asp-controller="Language" asp-action="Set" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            @if (currentCulture == "zh")
            {
                <button type="submit" name="culture" value="en-US" class="btn btn-sm btn-outline-secondary">English</button>
            }
            else
            {
                <button type="submit" name="culture" value="zh-CN" class="btn btn-sm btn-outline-secondary">中文</button>
            }
        </form>
    </div>

    <div class="logout-card">
        <div class="logout-icon">
            <i class="bi bi-check-lg"></i>
        </div>
        <h1 class="logout-title">@T["LogoutTitle"]</h1>
        <p class="logout-message">@T["LogoutMessage"]</p>

        <div class="spinner"></div>

        <p class="text-muted small mb-4">@T["AutoRedirectNotice"]</p>

        <a href="@Url.Action("Login", "Account", new { area = "Admin" })" class="btn-login">
            <i class="bi bi-box-arrow-in-right me-2"></i>@T["LoginNowButton"]
        </a>
    </div>

    <script>
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>
</body>
</html>
