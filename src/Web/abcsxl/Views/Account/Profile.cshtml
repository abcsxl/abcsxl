@using abcsxl.Models.ViewModels.Account
@*
    ============================================
    个人资料页面 - Profile.cshtml
    ============================================
*@

@model ProfileViewModel
@{
    ViewData["Title"] = "个人资料";
}

<div class="row">
    <div class="col-lg-4">
        <!-- 个人资料卡片 -->
        <div class="content-card">
            <div class="text-center mb-4">
                <div class="user-avatar-large mx-auto mb-3">
                    @{
                        var initial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A";
                    }
                    @initial
                </div>
                <h4 class="fw-bold mb-1">@(User.Identity?.Name ?? "管理员")</h4>
                <p class="text-muted mb-0">系统管理员</p>
                <span class="badge bg-primary mt-2">Admin</span>
            </div>

            <hr class="my-4">

            <div class="d-flex justify-content-between mb-3">
                <span class="text-muted"><i class="bi bi-envelope me-2"></i>邮箱</span>
                <span class="fw-medium">admin@example.com</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
                <span class="text-muted"><i class="bi bi-calendar me-2"></i>加入时间</span>
                <span class="fw-medium">2024-01-15</span>
            </div>
            <div class="d-flex justify-content-between mb-3">
                <span class="text-muted"><i class="bi bi-shield me-2"></i>最后登录</span>
                <span class="fw-medium">2024-03-20 14:30</span>
            </div>

            <hr class="my-4">

            <div class="d-grid gap-2">
                <button class="btn btn-outline-primary" onclick="location.href='@Url.Action("ChangePassword")'">
                    <i class="bi bi-key me-2"></i>修改密码
                </button>
                <button class="btn btn-outline-danger" onclick="location.href='@Url.Action("Logout")'">
                    <i class="bi bi-box-arrow-right me-2"></i>退出登录
                </button>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <!-- 编辑资料表单 -->
        <div class="content-card">
            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-pencil-square fs-4 me-2" style="color: var(--sidebar-active);"></i>
                <h5 class="fw-bold mb-0">编辑个人资料</h5>
            </div>

            <form asp-action="Profile" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">用户名</label>
                        <input type="text" class="form-control" name="UserName" value="@(User.Identity?.Name)" placeholder="请输入用户名">
                        <div class="form-text">用于登录的唯一标识</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-medium">显示名称</label>
                        <input type="text" class="form-control" name="DisplayName" value="管理员" placeholder="请输入显示名称">
                        <div class="form-text">前台显示的昵称</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-medium">电子邮箱</label>
                        <input type="email" class="form-control" name="Email" value="admin@example.com" placeholder="请输入邮箱">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-medium">手机号码</label>
                        <input type="tel" class="form-control" name="Phone" value="13800138000" placeholder="请输入手机号">
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-medium">个人简介</label>
                        <textarea class="form-control" name="Bio" rows="3" placeholder="介绍一下自己...">热爱技术，专注.NET开发</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-medium">头像</label>
                        <div class="d-flex align-items-center gap-3">
                            <div class="user-avatar" style="width: 64px; height: 64px; font-size: 1.5rem;">
                                @initial
                            </div>
                            <div>
                                <button type="button" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-upload me-1"></i>上传新头像
                                </button>
                                <div class="form-text mt-1">支持 JPG、PNG 格式，最大 2MB</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 mt-4">
                        <hr>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="reset" class="btn btn-light px-4">
                                <i class="bi bi-x-circle me-2"></i>取消
                            </button>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-2"></i>保存修改
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- 最近活动 -->
        <div class="content-card mt-4">
            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-activity fs-4 me-2" style="color: var(--sidebar-active);"></i>
                <h5 class="fw-bold mb-0">最近活动</h5>
            </div>

            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker bg-primary"></div>
                    <div class="timeline-content">
                        <div class="d-flex justify-content-between">
                            <span class="fw-medium">登录系统</span>
                            <small class="text-muted">5分钟前</small>
                        </div>
                        <small class="text-muted">IP: 192.168.1.100</small>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-marker bg-success"></div>
                    <div class="timeline-content">
                        <div class="d-flex justify-content-between">
                            <span class="fw-medium">更新文章</span>
                            <small class="text-muted">1小时前</small>
                        </div>
                        <small class="text-muted">《ASP.NET Core 入门教程》</small>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-marker bg-info"></div>
                    <div class="timeline-content">
                        <div class="d-flex justify-content-between">
                            <span class="fw-medium">修改密码</span>
                            <small class="text-muted">3天前</small>
                        </div>
                        <small class="text-muted">IP: 192.168.1.100</small>
                    </div>
                </div>
            </div>

            <div class="text-center mt-3">
                <a href="#" class="text-decoration-none small">
                    查看全部活动 <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .user-avatar-large {
        width: 100px;
        height: 100px;
        border-radius: 20px;
        background: linear-gradient(145deg, var(--sidebar-active), #0b5ed7);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 2.5rem;
        box-shadow: 0 10px 20px rgba(13,110,253,0.2);
    }

    .timeline {
        position: relative;
        padding-left: 1.5rem;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 7px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e2e8f0;
        }

    .timeline-item {
        position: relative;
        padding-bottom: 1.5rem;
    }

    .timeline-marker {
        position: absolute;
        left: -1.5rem;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .timeline-content {
        padding-left: 0.5rem;
    }

    [data-bs-theme="dark"] .timeline::before {
        background: #475569;
    }

    [data-bs-theme="dark"] .timeline-marker {
        border-color: #1e293b;
    }

    .form-control {
        border-radius: 10px;
        border: 2px solid #e2e8f0;
        padding: 0.6rem 1rem;
        transition: all 0.2s;
    }

        .form-control:focus {
            border-color: var(--sidebar-active);
            box-shadow: 0 0 0 4px rgba(13,110,253,0.1);
        }

    .btn-outline-primary {
        border-width: 2px;
        border-radius: 10px;
    }

    .btn-outline-danger {
        border-width: 2px;
        border-radius: 10px;
    }
</style>