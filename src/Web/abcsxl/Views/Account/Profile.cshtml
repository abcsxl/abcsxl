@model abcsxl.Models.ViewModels.Account.ProfileViewModel
@{
    ViewData["Title"] = "个人资料";
}

<header class="masthead" style="background-image: url('../images/home-bg.webp')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-9 col-xl-8">
                <div class="site-heading">
                    <h1>@ViewData["Title"]</h1>
                    <span class="subheading">
                        管理您的个人账户信息
                    </span>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="container px-4 px-lg-5">
    <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-md-10 col-lg-9 col-xl-8">
            <div class="clearfix">
                <!-- 左侧：个人信息 -->
                <div class="col-lg-4 float-start pe-lg-4 mb-4">
                    <div class="card">
                        <div class="card-body text-center">
                            @{
                                var initial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A";
                            }
                            <div class="user-avatar-large mx-auto mb-3">@initial</div>
                            <h4>@(User.Identity?.Name ?? "管理员")</h4>
                            <p class="text-muted mb-2">系统管理员</p>
                            <span class="badge bg-primary">Admin</span>

                            <hr>

                            <div class="text-start">
                                <p class="mb-2"><i class="bi bi-envelope me-2"></i>admin@example.com</p>
                                <p class="mb-2"><i class="bi bi-calendar me-2"></i>2024-01-15</p>
                            </div>

                            <hr>

                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-primary" onclick="location.href='@Url.Action("ChangePassword")'">
                                    <i class="bi bi-key me-2"></i>修改密码
                                </button>
                                <button class="btn btn-outline-danger" onclick="location.href='@Url.Action("Logout")'">
                                    <i class="bi bi-box-arrow-right me-2"></i>退出登录
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 右侧：编辑表单 -->
                <div class="col-lg-8 float-end">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>编辑个人资料</h5>
                        </div>
                        <div class="card-body">
                            <form asp-action="Profile" method="post">
                                @Html.AntiForgeryToken()

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">用户名</label>
                                        <input type="text" class="form-control" name="UserName" value="@User.Identity?.Name">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">显示名称</label>
                                        <input type="text" class="form-control" name="DisplayName" value="管理员">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">电子邮箱</label>
                                        <input type="email" class="form-control" name="Email" value="admin@example.com">
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">手机号码</label>
                                        <input type="tel" class="form-control" name="Phone" value="">
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">个人简介</label>
                                        <textarea class="form-control" name="Bio" rows="3"></textarea>
                                    </div>

                                    <div class="col-12 mt-4">
                                        <div class="d-flex gap-2 justify-content-end">
                                            <button type="reset" class="btn btn-secondary">取消</button>
                                            <button type="submit" class="btn btn-primary">保存修改</button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.user-avatar-large {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: #0078d4;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 2.5rem;
}
</style>