@model abcsxl.Models.ViewModels.Home.HomeIndexViewModel

@{
    ViewData["Title"] = "abcsxl";
}

<!-- Page Header-->
<header class="masthead" style="background-image: url('images/home-bg.webp')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-9 col-xl-8">
                <div class="site-heading">
                    <h1>启旭拾光</h1>
                    <span class="subheading">
@*                         To undertake the endeavors of life with the awareness of its impermanence,
                        To live an optimistic life with a contemplative acceptance of its sorrows. *@
                        以无生之觉悟为有生之事业，以悲观之心情过乐观之生活。
                    </span>
                </div>
            </div>
        </div>
    </div>
</header>
<!-- Main Content-->
<div class="container px-4 px-lg-5">
    <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-md-10 col-lg-9 col-xl-8">
            @foreach (var item in Model.LastPosts!)
            {
                <!-- Post preview-->
                <div class="post-preview">
                    <a asp-area="" asp-controller="Post" asp-action="Details" asp-route-id="@item.Id">
                        <h2 class="post-title">@Html.DisplayFor(modelItem => item.Title)</h2>
                        <h3 class="post-subtitle">@Html.DisplayFor(modelItem => item.Excerpt)</h3>
                    </a>
                    <p class="post-meta">
                        Posted by
                        <a href="#!">@Html.DisplayFor(modelItem => item.Author)</a>
                        on 
                        @Html.DisplayFor(modelItem => item.PublishedAt)
                    </p>
                </div>
                <!-- Divider-->
                <hr class="my-4" />
            }
            <!-- Pager-->
            <div class="d-flex justify-content-end mb-4"><a class="btn btn-primary text-uppercase" asp-area="" asp-controller="Post" asp-action="Index">More →</a></div>
        </div>
    </div>
</div>
