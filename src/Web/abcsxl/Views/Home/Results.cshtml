@model abcsxl.Models.ViewModels.Home.SearchResultViewModel
@{
    ViewData["Title"] = !string.IsNullOrEmpty(Model.Query)
        ? T["TitleWithQuery", Model.Query].Value
        : T["TitleEmpty"].Value;
}

@section Styles
{
    <link rel="stylesheet" href="~/css/page-specific-results.css" />
}

<!-- Page Header-->
<header class="masthead" style="background-image: url('../images/results-bg.webp')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-9 col-xl-8">
                <div class="site-heading">
                    <h1>@ViewData["Title"]</h1>
                    <span class="subheading">@T["Subtitle"]</span>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Main Content-->
<div class="container px-4 px-lg-5">
    <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-md-10 col-lg-9 col-xl-8">

            <div class="search-section">
                <div class="container">
                    <form method="get" class="search-box-container">
                        <input type="text" name="q" class="search-box" placeholder="@T["SearchPlaceholder"]" value="@Model.Query">
                        <input type="hidden" name="tab" value="@Model.ActiveTab" />
                        <button type="submit" class="search-button">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Query))
            {
                <div class="results-header">
                    <div class="results-count">@T["ResultsCount", Model.TotalCount, Model.Query]</div>
                    <div class="results-tabs" id="resultsTabs">
                        <a href="@Url.Action("Results", "Home", new { q = Model.Query, tab = "all" })" class="tab @(Model.ActiveTab == "all" ? "active" : "")">@T["TabAll"]</a>
                        <a href="@Url.Action("Results", "Home", new { q = Model.Query, tab = "post" })" class="tab @(Model.ActiveTab == "post" ? "active" : "")">@T["TabPost"]</a>
                        <a href="@Url.Action("Results", "Home", new { q = Model.Query, tab = "category" })" class="tab @(Model.ActiveTab == "category" ? "active" : "")">@T["TabCategory"]</a>
                        <a href="@Url.Action("Results", "Home", new { q = Model.Query, tab = "tag" })" class="tab @(Model.ActiveTab == "tag" ? "active" : "")">@T["TabTag"]</a>
                    </div>
                </div>

                <div class="results-container" id="resultsContainer">
                    @if (Model.ActiveTab == "all" || Model.ActiveTab == "post")
                    {
                        @foreach (var post in Model.Posts)
                        {
                            <div class="result-item">
                                <span class="result-category">@T["CategoryPost"]</span>
                                <a href="@post.Url" class="result-title">@post.Title</a>
                                <p class="result-description">@post.Excerpt</p>
                                <small class="text-muted">@post.Author · @post.PublishedAt.ToString("yyyy-MM-dd")</small>
                            </div>
                        }
                    }

                    @if (Model.ActiveTab == "all" || Model.ActiveTab == "category")
                    {
                        @foreach (var category in Model.Categories)
                        {
                            <div class="result-item">
                                <span class="result-category">@T["CategoryCategory"]</span>
                                <a href="@category.Url" class="result-title">@category.Name</a>
                                <small class="text-muted">@T["PostCountFormat", category.PostCount]</small>
                            </div>
                        }
                    }

                    @if (Model.ActiveTab == "all" || Model.ActiveTab == "tag")
                    {
                        @foreach (var tag in Model.Tags)
                        {
                            <div class="result-item">
                                <span class="result-category">@T["CategoryTag"]</span>
                                <a href="@tag.Url" class="result-title">@tag.Name</a>
                                <small class="text-muted">@T["PostCountFormat", tag.PostCount]</small>
                            </div>
                        }
                    }

                    @if (Model.TotalCount == 0)
                    {
                        <div class="text-center py-5">
                            <p class="text-muted">@T["NoResultsMessage"]</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <p class="text-muted">@T["EnterQueryMessage"]</p>
                </div>
            }

        </div>
    </div>
</div>
