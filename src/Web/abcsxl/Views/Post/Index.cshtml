@using abcsxl.Helpers
@model abcsxl.Models.ViewModels.Post.IndexPageViewModel

@{
    ViewData["Title"] = "全部文章";
}

@section Styles
{
    <link rel="stylesheet" href="~/css/page-specific-posts.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<!-- Page Header-->
<header class="masthead" style="background-image: url('../images/posts-bg.webp')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-9 col-xl-8">
                <div class="site-heading">
                    <h1>@ViewData["Title"]</h1>
                    <span class="subheading">
                        @*To undertake the endeavors of life with the awareness of its impermanence,
                        To live an optimistic life with a contemplative acceptance of its sorrows. *@
                        以无生之觉悟为有生之事业，以悲观之心情过乐观之生活。
                    </span>
                </div>
            </div>
        </div>
    </div>
</header>


<div class="container px-4 px-lg-5">
    <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-md-10 col-lg-9 col-xl-6">

            @foreach (var item in Model.Posts)
            {
                <!-- Post preview-->
                <div class="post-preview">
                    <a asp-action="Details" asp-route-id="@item.Id">
                        <h2 class="post-title">@Html.DisplayFor(modelItem => item.Title)</h2>
                        <h3 class="post-subtitle">@Html.DisplayFor(modelItem => item.Excerpt)</h3>
                    </a>
                    <p class="post-meta">
                        Posted by
                        <a href="#!">@Html.DisplayFor(modelItem => item.Author.Name)</a>
                        on
                        @Html.DisplayFor(modelItem => item.PublishedTime)
                        @if (item.Categories != null && item.Categories.Any())
                        {
                            <span class="mx-2">•</span>
                            @foreach (var c in item.Categories)
                            {
                                <a class="badge bg-primary text-decoration-none category-card"
                                   asp-action="Details"
                                   asp-route-id="@c.Id">
                                    @Html.DisplayFor(citem => c.Title)
                                </a>
                            }
                        }
                    </p>
                    <div class="mt-2">
                        @if (item.Tags != null && item.Tags.Any())
                        {
                            @foreach (var t in item.Tags)
                            {
                                <a href="#!" class="badge bg-light text-dark text-decoration-none me-1">
                                    @Html.DisplayFor(tItem => t.Title)
                                </a>
                            }
                        }
                    </div>
                </div>
                <!-- Divider-->
                <hr class="my-4" />
            }

            <!-- 分页 -->
            <div class="pagination-container d-flex justify-content-between align-items-center">
                @{
                    var pagination = PaginationHelper.GetPaginationModel(Model.CurrentPage, Model.TotalPages);
                    var startItem = Model.CurrentPage == 0 ? Model.CurrentPage : (Model.CurrentPage - 1) * Model.PageSize + 1;
                    var endItem = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
                }
                <div class="text-muted">Showing @startItem-@endItem of @Model.TotalCount articles</div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0">
                            <!-- 上一页 -->
                            <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                                @if (Model.HasPrevious)
                                {
                                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-pageSize="@Model.PageSize" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                }
                                else
                                {
                                    <a class="page-link" href="#" aria-label="Previous">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                }
                            </li>

                            <!-- 第一页 -->
                            <li class="page-item @(Model.CurrentPage == 1 ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-pageSize="@Model.PageSize">1</a>
                            </li>

                            <!-- 左省略号 -->
                            @if (pagination.ShowLeftEllipsis)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <!-- 中间三个页码 -->
                            @foreach (var i in pagination.MiddlePages)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                                </li>
                            }

                            <!-- 右省略号 -->
                            @if (pagination.ShowRightEllipsis)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <!-- 最后一页 -->
                            @if (Model.TotalPages > 1)
                            {
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                                </li>
                            }

                            <!-- 下一页 -->
                            <li class="page-item @(Model.HasNext ? "" : "disabled")">
                                @if (Model.HasNext)
                                {
                                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-pageSize="@Model.PageSize" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                }
                                else
                                {
                                    <a class="page-link" href="#" aria-label="Next">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                }
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
        <!-- 侧边栏（大屏幕显示） -->
        <div class="col-lg-3 d-none d-lg-block">
            @await Html.PartialAsync("_CategorySidebar", Model.SidebarCategories)
            @await Html.PartialAsync("_TagSidebar", Model.SidebarTags)
        </div>
    </div>
</div>
