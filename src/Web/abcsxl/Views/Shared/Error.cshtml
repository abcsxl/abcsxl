@using abcsxl.Models.ViewModels
@model ErrorViewModel
@{
    ViewData["Title"] = T["PageTitle"].Value;
}

<h1 class="text-danger">@T["Heading"]</h1>
<h2 class="text-danger">@T["Subheading"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@T["RequestIdLabel"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@T["DevModeHeading"]</h3>
<p>@T["DevModeBody"]</p>
<p>
    <strong>@T["DevModeWarning"]</strong>
    @T["DevModeBody2"]
    @T["DevModeBody3"]
</p>
